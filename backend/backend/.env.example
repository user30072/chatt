# Application
NODE_ENV=development
PORT=3001

# Database - PostgreSQL connection
PGVECTOR_URL=postgresql://postgres:postgres@localhost:5432/chatbot_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatbot_db

# JWT Authentication
JWT_SECRET=your-secret-key-here
JWT_EXPIRY=7d

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# CORS Configuration
# Comma-separated list of allowed origins (no spaces after commas)
CORS_ORIGIN=https://your-frontend-url.up.railway.app,https://www.yourdomain.com
FRONTEND_URL=http://localhost:3000

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com

# Admin Authentication
ADMIN_TOKEN=eb89b59bf83ba63bc6c6c347728dbd21f927246d3230b7826574ca243cf4cb2e

# File Storage 
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB 

# Email Configuration for notifications
EMAIL_USER=askanybot@gmail.com
EMAIL_PASSWORD=your_app_password_here
ADMIN_EMAIL=askanybot@gmail.com

# Note: For Gmail, use an App Password instead of your regular password
# Generate one at: https://myaccount.google.com/apppasswords
# You'll need to have 2-Step Verification enabled on your Google account 

# Stripe API Keys (for subscription payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Stripe Price IDs for subscription plans
STRIPE_PRICE_BASIC_MONTHLY=price_xxx
STRIPE_PRICE_BASIC_YEARLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_YEARLY=price_xxx

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret 