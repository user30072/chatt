    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.6.9",
    "nodemailer": "^6.9.7",
