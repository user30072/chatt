# This is a template file for Railway deployment
# Railway will inject actual environment variables automatically

# Environment variables for database connection
DATABASE_URL=${DATABASE_URL}
PGVECTOR_URL=${DATABASE_URL}

# JWT Authentication
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRY="7d"

# OpenAI API Configuration
OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_MODEL="gpt-4o"

# Server Configuration
PORT=3001
NODE_ENV="production"

# CORS Configuration - allow your frontend domain without trailing slash
CORS_ORIGIN="*"
FRONTEND_URL=${FRONTEND_URL}

# Email Configuration
EMAIL_USER=${EMAIL_USER}
EMAIL_PASSWORD=${EMAIL_PASSWORD}
ADMIN_EMAIL=${ADMIN_EMAIL}

# Admin Authentication
ADMIN_TOKEN=${ADMIN_TOKEN}

# For Prisma
POSTGRES_URL=${DATABASE_URL} 