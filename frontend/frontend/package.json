{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prepare": "echo 'Running prepare script - for widget setup'",
    "verify-imports": "node verify-imports.js",
    "build": "npm run verify-imports && SKIP_LINT=true next build",
    "build:widget": "cd src/widget && mkdir -p dist && npx webpack",
    "build:all": "npm run build:widget && mkdir -p public/widget && cp -f src/widget/dist/widget.js public/widget/ && SKIP_LINT=true npm run build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.4",
    "@chakra-ui/react": "^3.15.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^5.11.0",
    "@react-oauth/google": "^0.12.1",
    "axios": "^1.8.4",
    "browserslist": "^4.26.2",
    "caniuse-lite": "^1.0.30001745",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.6.5",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.487.0",
    "next": "^15.3.8",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.10.1",
    "react": "^19.0.0",
    "react-color": "^2.19.3",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.55.0",
    "recharts": "^2.15.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-loader": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "15.3.0",
    "tailwindcss": "^4",
    "terser-webpack-plugin": "^5.3.9",
    "typescript": "^5",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  }
